# ============================================================
# Morning Briefing Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Anthropic (Required) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Microsoft Graph / Outlook ────────────────────────────────
# Azure App Registration → Application (client) ID
MS_CLIENT_ID=your-azure-app-client-id-here
# 'common' for personal accounts; your org tenant ID for work accounts
MS_TENANT_ID=common
MS_TOKEN_CACHE=.ms_token_cache.json

# ── Evernote ─────────────────────────────────────────────────
# Get token: https://www.evernote.com/api/DeveloperToken.action
EVERNOTE_TOKEN=your-evernote-developer-token-here
# Optional: filter to specific notebook by exact name
EVERNOTE_NOTEBOOK=Daily Notes
EVERNOTE_SANDBOX=false

# ── Jira ─────────────────────────────────────────────────────
# Your Atlassian instance URL (no trailing slash)
JIRA_BASE_URL=https://attainpartners.atlassian.net
# Your Atlassian account email
JIRA_EMAIL=mjdavis@attainpartners.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-atlassian-api-token-here
# Your Jira account ID (pre-filled — do not change unless logging in as someone else)
JIRA_ASSIGNEE_ACCOUNT_ID=618d7b2af1ff560069e000d6

# ── Jira Project Key Mapping ─────────────────────────────────
# These are baked into classifier.py — edit there if you add new clients.
# Current mappings:
#   SEED Foundation              → SEED
#   Michigan SBDC / GVSU         → MSBDC
#   UPenn Student Success        → USS
#   AAUM Managed Services        → AMS
#   MIDAS / Beatrice Hahn        → AMS  (+ flag for MIDAS Board)
#   Darden / Darden ExecEd       → DARDENEXED
#   Attain Partners / Internal   → AMS

# ── Slack (Optional) ─────────────────────────────────────────
# Leave blank to skip Slack posting
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── Behavior ─────────────────────────────────────────────────
YOUR_NAME=Maury
YOUR_CLIENTS=SEED Foundation,Michigan SBDC,UPenn Student Success,AAUM,MIDAS,Darden,Attain Partners
EMAIL_MAX_FETCH=50
EMAIL_FOLDERS=inbox
